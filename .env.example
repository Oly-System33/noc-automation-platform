# Runtime
PUBLIC_BASE_URL=http://3.89.189.230:8000
RUNBOOKS_PATH=/app/runbooks

# Console logging
CONSOLE_COLORS=auto
CONSOLE_LOG_MODE=demo
CONSOLE_LOG_LEVEL=INFO

# Telegram
TELEGRAM_BOT_TOKEN_NOC=replace-me

# Vonage Voice
VONAGE_APPLICATION_ID=replace-me
VONAGE_PRIVATE_KEY_PATH=/app/private.key
VONAGE_FROM_NUMBER=replace-me
VONAGE_API_BASE_URL=https://api.nexmo.com/v1/calls
CALL_RESOLUTION_TIMEOUT_SECONDS=90

# SMTP
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me

# Jira
JIRA_URL=https://example.atlassian.net
JIRA_EMAIL=replace-me
JIRA_API_TOKEN=replace-me
JIRA_ISSUE_TYPE=Task
JIRA_TIMEOUT_SECONDS=5

# PostgreSQL
# Local app + PostgreSQL in Docker:
DATABASE_URL=postgresql://noc_engine:noc_engine@localhost:5432/noc_engine
# Docker Compose app + PostgreSQL service:
# DATABASE_URL=postgresql://noc_engine:noc_engine@postgres:5432/noc_engine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=noc_engine
POSTGRES_USER=noc_engine
POSTGRES_PASSWORD=noc_engine

# Scheduled actions worker
SCHEDULED_ACTION_WORKER_ENABLED=true
SCHEDULED_ACTION_POLL_INTERVAL_SECONDS=5
SCHEDULED_ACTION_BATCH_SIZE=20
SCHEDULED_ACTION_PROCESSING_TIMEOUT_MINUTES=10
SCHEDULED_ACTION_MAX_ATTEMPTS=3
